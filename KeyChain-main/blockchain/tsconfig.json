{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["./scripts", "./test", "./hardhat.config.ts", "./typechain-types"]
}
