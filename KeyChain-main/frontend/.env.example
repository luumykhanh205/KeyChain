# ── Public (exposed to browser) ──
NEXT_PUBLIC_ALCHEMY_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_CHAIN_ID=11155111

# Contract addresses — fill after deploying to Sepolia
NEXT_PUBLIC_KEYCOIN_ADDRESS=
NEXT_PUBLIC_GAMETOKEN_ADDRESS=
NEXT_PUBLIC_GAMESTORE_ADDRESS=
NEXT_PUBLIC_ACTIVATION_ADDRESS=
NEXT_PUBLIC_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_GAMEPASS_ADDRESS=

# Dedicated Pinata gateway for displaying IPFS images (e.g. your-gateway.mypinata.cloud)
NEXT_PUBLIC_PINATA_GATEWAY=

# ── Server-only (API routes, not exposed to browser) ──
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=your-gateway.mypinata.cloud
